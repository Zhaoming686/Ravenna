{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build with cmake",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "run-test-release"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "run SubgraphMatching",
      "type": "process",
      "command": "${workspaceFolder}/test1/matching/SubgraphMatching.out",
      "args": [
        "-d",
        "${workspaceFolder}/datasets/original/data_graph/patents.graph",
        "-q",
        "${workspaceFolder}/datasets/original/query_graph/patents/query_G_12_1.graph",
        "-filter",
        "VEQ",
        "-order",
        "CFL",
        "-engine",
        "Ravenna",
        "-num",
        "-1",
        "-symmetry",
        "1",
        "-FairT",
        "2",
        "-time",
        "2",
        "-SF",
        "Coverage",
        "-tau",
        "0.12, 0.37, 0.04, 0.48, 0.21, 0.33, 0.09, 0.45, 0.16, 0.29, 0.50, 0.07, 0.41, 0.26, 0.18, 0.02, 0.35, 0.11, 0.44, 0.23"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LD_LIBRARY_PATH": "/opt/software/gcc/13.2.0/lib64:${env:LD_LIBRARY_PATH}"
        }
      },
      "dependsOn": "build with cmake",
      "problemMatcher": []
    }
  ]
}